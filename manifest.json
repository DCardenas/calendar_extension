{
  "manifest_version": 3,
  "name": "Dropply",
  "version": "1.0.0",
  "description": "Drag and drop .ics files directly into Google Calendar",
  "icons": {
    "16": "res/calendar_16x16.png",
    "48": "res/calendar_48x48.png",
    "128": "res/calendar_128x128.png"
  },
  "permissions": ["identity"],
  "host_permissions": [
    "https://calendar.google.com/*",
    "https://www.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "833481649206-tnsee5ojvt5hcg3i69obg0vcn4jiqmq0.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/calendar.events"]
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://calendar.google.com/*"],
      "js": ["libs/ical.min.js", "dist/content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
